{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@server/*": ["./src/server/*"],
      "@proxy/*": ["./src/proxy/*"],
      "@config/*": ["./src/config/*"],
      "@rate-limit/*": ["./src/rate-limit/*"],
      "@fallback/*": ["./src/fallback/*"],
      "@logging/*": ["./src/logging/*"],
      "@store/*": ["./src/store/*"],
      "@middleware/*": ["./src/middleware/*"],
      "@cli/*": ["./src/cli/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
