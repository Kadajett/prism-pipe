{
  "name": "prism-pipe",
  "version": "0.1.0",
  "description": "AI proxy with configurable rate limiting, fallbacks, logging, and multi-IP egress",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "biome check .",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": ["ai", "proxy", "rate-limiting", "fallback", "multi-ip"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "express": "^5.1.0",
    "minimist": "^1.2.8",
    "pino": "^9.6.0",
    "ulid": "^2.3.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
