{
  "name": "prism-pipe",
  "version": "0.1.0",
  "description": "AI proxy with configurable rate limiting, fallbacks, logging, and multi-IP egress",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "ai",
    "proxy",
    "rate-limiting",
    "fallback",
    "multi-ip"
  ],
  "license": "MIT",
  "dependencies": {
    "minimist": "^1.2.8",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
