{
  "name": "prism-pipe",
  "version": "0.1.0",
  "description": "AI proxy with configurable rate limiting, fallbacks, logging, and multi-IP egress",
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    },
    "./config": {
      "import": "./dist/config/loader.js",
      "types": "./dist/config/loader.d.ts"
    }
  },
  "bin": {
    "prism-pipe": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "prism-pipe.example.yaml"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "build:check": "tsc --noEmit && tsup",
    "start": "node dist/index.js",
    "prepare": "git config core.hooksPath .githooks || true",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "ai",
    "proxy",
    "openai",
    "anthropic",
    "rate-limiting",
    "fallback",
    "multi-ip",
    "llm"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "ulid": "^3.0.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/aws-lambda": "^8.10.161",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/supertest": "^7.2.0",
    "msw": "^2.12.10",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
